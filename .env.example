# Скопируй в .env.local и заполни. .env.local в git не коммитится.

# API
NEXT_PUBLIC_API_URL=https://instagram-api.softclub.tj
NEXT_PUBLIC_EXTRA_API_URL=https://instagramextraapi.onrender.com

# Auth.js (NextAuth) — вход через Google.
# AUTH_SECRET: сгенерируй командой `npx auth secret` или `openssl rand -base64 33`.
AUTH_SECRET=
# Google Cloud Console → APIs & Services → Credentials → OAuth client ID (Web application).
# Authorized redirect URI: http://localhost:3000/api/auth/callback/google
# (для прода добавь https://ТВОЙ-домен/api/auth/callback/google)
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
